{
  "name": "conveyor",
  "private": true,
  "version": "1.0.0",
  "description": "AI With PC Control Platform",
  "author": "ByoungChan",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host",
    "dev:mobile": "node scripts/dev-mobile.mjs",
    "dev:mobile:preview": "node scripts/dev-mobile.mjs --preview",
    "dev:semicnv-mock": "node scripts/mock-semicnv-ws.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview --host",
    "gen:icon": "node scripts/gen-icon.mjs",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on tcp:127.0.0.1:5173 && electron electron/main.cjs\"",
    "electron:pack": "cross-env ELECTRON=1 vite build && electron-builder --dir",
    "electron:build": "cross-env ELECTRON=1 vite build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "uuid": "^14.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10",
    "ws": "^8.18.3"
  }
}
